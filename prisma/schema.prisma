generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum App {
  DD
  RF
}

enum SubscriptionTier {
  BRONZE
  SILVER
  GOLD
}

model Account {
  id            String   @id @default(uuid())
  app           App
  email         String
  passwordHash  String   @map("password_hash")
  unifiedUserId String?  @map("unified_user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  ddProfile      DdProfile?
  ddSubscription DdSubscription?

  @@unique([app, email])
  @@index([email])
  @@index([unifiedUserId])
  @@map("accounts")
}

model DdProfile {
  id        String   @id @default(uuid())
  accountId String   @unique @map("account_id")
  postcode  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("dd_profile")
}

model DdSubscription {
  id        String           @id @default(uuid())
  accountId String           @unique @map("account_id")
  tier      SubscriptionTier
  active    Boolean          @default(true)
  startedAt DateTime         @default(now()) @map("started_at")
  renewsAt  DateTime         @map("renews_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("dd_subscriptions")
}

model Store {
  id        String   @id @default(uuid())
  name      String
  address   String?
  city      String?
  postcode  String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products    StoreProduct[]
  storeOrders StoreOrder[]

  @@map("stores")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  brand     String?
  unit      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stores          StoreProduct[]
  storeOrderItems StoreOrderItem[]

  @@map("products")
}

model StoreProduct {
  storeId   String @map("store_id")
  productId String @map("product_id")

  pricePence Int     @map("price_pence")
  inStock    Boolean @default(true) @map("in_stock")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([storeId, productId])
  @@index([productId])
  @@map("store_products")
}

model Order {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  createdAt DateTime @default(now()) @map("created_at")

  storeOrders StoreOrder[]

  @@index([accountId])
  @@map("orders")
}

model StoreOrder {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  storeId   String   @map("store_id")
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  items StoreOrderItem[]

  @@index([orderId])
  @@index([storeId])
  @@map("store_orders")
}

model StoreOrderItem {
  id           String @id @default(uuid())
  storeOrderId String @map("store_order_id")
  productId    String @map("product_id")
  quantity     Int
  pricePence   Int    @map("price_pence")

  storeOrder StoreOrder @relation(fields: [storeOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeOrderId])
  @@index([productId])
  @@map("store_order_items")
}